# Copy to .env and adjust.

# MongoDB Atlas: paste URI from Atlas → Connect → Drivers; Network Access must allow your IP.
# Local MongoDB (mongod on this machine): mongodb://127.0.0.1:27017/p2p-platform
MONGODB_URI=mongodb://127.0.0.1:27017/p2p-platform

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

EMAIL_USER=
EMAIL_PASS=

GROQ_API_KEY=
